{
  "name": "encircle-commit-guard",
  "version": "1.2.19",
  "description": "CLI tool to validate project structure, code quality, and common issues",
  "main": "src/runner.js",
  "bin": {
    "commit-guard": "bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "start": "node bin/cli.js",
    "postinstall": "node bin/postinstall.js"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "commit-guard",
    "folder-structure",
    "code-quality",
    "console-log",
    "lint",
    "cli",
    "typescript",
    "node"
  ],
  "author": "bishan42",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "docx": "^9.7.1",
    "glob": "^10.3.0",
    "minimatch": "^9.0.0"
  },
  "peerDependencies": {
    "eslint": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    }
  }
}